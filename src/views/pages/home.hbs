<div class="container py-4">

  <h1 class="page-title">Lista de productos / Product List</h1>

  <div class="row g-4" id="productsList">
    {{#if products.length}}
      {{#each products}}
        <div class="col-md-4 col-sm-6">
          <div class="card product-card h-100 shadow-sm">
            <div class="card-body">

              <h5 class="card-title product-title">{{this.title}}</h5>

              <p class="card-text text-body-secondary product-id">ID: {{this._id}}</p>

              <p class="card-text product-info"><strong>Price:</strong> ${{this.price}}</p>

              <p class="card-text product-info"><strong>Stock:</strong> {{this.stock}}</p>
              <a href="/products/{{this._id}}" class="btn btn-primary btn-sm mt-2">Ver detalle / See details</a>

            </div>
          </div>
        </div>
      {{/each}}
    {{else}}
      <div class="col-12">
        <p class="no-products">No hay productos cargados / No products uploaded.</p>
      </div>
    {{/if}}
  </div>

  <div class="load-products-container mt-4">
    <a href="/realtimeproducts" class="load-products-btn">Ir a tiempo real / Go to realtime</a>
  </div>

</div>